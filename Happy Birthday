<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8" />
<meta name="viewport" content="width=device-width, initial-scale=1.0"/>
<title>Anjali Special 💖</title>

<link href="https://fonts.googleapis.com/css2?family=Poppins:wght@300;400;600;700&family=Great+Vibes&display=swap" rel="stylesheet">

<style>

*{
  margin:0;
  padding:0;
  box-sizing:border-box;
}

body{
  height:100vh;
  overflow:hidden;
  display:flex;
  justify-content:center;
  align-items:center;
  font-family:'Poppins',sans-serif;
  background:linear-gradient(-45deg,#ff006e,#ff4d9d,#ff85b3,#ffc2d1,#ffe5ec);
  background-size:400% 400%;
  animation:bgMove 10s ease infinite;
  position:relative;
}

/* GLOW BACKGROUND */
body::before{
  content:'';
  position:absolute;
  width:500px;
  height:500px;
  background:rgba(255,255,255,0.15);
  border-radius:50%;
  filter:blur(120px);
  top:-100px;
  left:-100px;
  animation:moveGlow 8s infinite alternate;
}

body::after{
  content:'';
  position:absolute;
  width:400px;
  height:400px;
  background:rgba(255,0,128,0.2);
  border-radius:50%;
  filter:blur(120px);
  bottom:-100px;
  right:-100px;
  animation:moveGlow2 10s infinite alternate;
}

/* MAIN CARD */
.container{
  position:relative;
  z-index:10;
  text-align:center;
  padding:50px;
  width:90%;
  max-width:700px;

  background:rgba(255,255,255,0.12);
  backdrop-filter:blur(15px);

  border:1px solid rgba(255,255,255,0.25);
  border-radius:35px;

  box-shadow:
  0 0 40px rgba(255,255,255,0.2),
  0 0 80px rgba(255,0,128,0.2);

  animation:cardFloat 4s ease-in-out infinite;
}

/* TITLE */
h1{
  font-size:85px;
  font-family:'Great Vibes',cursive;
  color:white;

  text-shadow:
  0 0 10px #fff,
  0 0 20px #ff4da6,
  0 0 40px #ff006e;

  animation:titleGlow 2s infinite alternate;
}

/* TEXT */
p{
  margin-top:15px;
  font-size:24px;
  color:white;
  letter-spacing:1px;
}

/* BUTTON */
.btn{
  margin-top:35px;
  padding:18px 55px;
  border:none;
  border-radius:60px;
  cursor:pointer;

  font-size:22px;
  font-weight:700;
  color:white;

  background:linear-gradient(45deg,#ff006e,#ff4da6,#ff85b3,#ff006e);
  background-size:300% 300%;

  box-shadow:
  0 0 20px rgba(255,255,255,0.5),
  0 0 40px rgba(255,0,110,0.6);

  transition:0.4s;
  animation:btnMove 4s infinite;
}

.btn:hover{
  transform:scale(1.12) translateY(-5px);
  box-shadow:
  0 0 30px white,
  0 0 60px hotpink;
}

/* BIRTHDAY PAGE */
.birthday-page{
  width:100%;
  height:100vh;

  display:flex;
  flex-direction:column;
  justify-content:center;
  align-items:center;
  text-align:center;

  z-index:10;
}

/* BIG TEXT */
.birthday-text{
  font-size:90px;
  font-family:'Great Vibes',cursive;
  color:white;

  text-shadow:
  0 0 15px white,
  0 0 30px #ff4da6,
  0 0 60px hotpink,
  0 0 100px deeppink;

  animation:bounce 1.5s infinite alternate;
}

.wish{
  margin-top:20px;
  font-size:30px;
  color:white;
  text-shadow:0 0 10px rgba(255,255,255,0.7);
}

/* HEARTS */
.heart{
  position:absolute;
  bottom:-50px;
  color:pink;
  animation:floatUp linear forwards;
  user-select:none;
}

/* SPARKLES */
.sparkle{
  position:absolute;
  width:8px;
  height:8px;
  border-radius:50%;
  background:white;
  box-shadow:0 0 15px white;
  animation:sparkleAnim 2s linear infinite;
}

/* CONFETTI */
.confetti{
  position:absolute;
  width:12px;
  height:12px;
  top:-20px;
  animation:confettiFall linear forwards;
}

/* ANIMATIONS */

@keyframes bgMove{
  0%{background-position:0% 50%;}
  50%{background-position:100% 50%;}
  100%{background-position:0% 50%;}
}

@keyframes titleGlow{
  from{
    transform:scale(1);
  }
  to{
    transform:scale(1.05);
  }
}

@keyframes btnMove{
  0%{background-position:0% 50%;}
  50%{background-position:100% 50%;}
  100%{background-position:0% 50%;}
}

@keyframes cardFloat{
  0%{transform:translateY(0px);}
  50%{transform:translateY(-10px);}
  100%{transform:translateY(0px);}
}

@keyframes bounce{
  from{
    transform:scale(1);
  }
  to{
    transform:scale(1.08);
  }
}

@keyframes floatUp{
  0%{
    transform:translateY(0) scale(0.5);
    opacity:0;
  }

  20%{
    opacity:1;
  }

  100%{
    transform:translateY(-120vh) scale(1.5);
    opacity:0;
  }
}

@keyframes confettiFall{
  0%{
    transform:translateY(0) rotate(0deg);
  }

  100%{
    transform:translateY(120vh) rotate(720deg);
  }
}

@keyframes sparkleAnim{
  0%{
    transform:scale(0);
    opacity:0;
  }

  50%{
    transform:scale(1.5);
    opacity:1;
  }

  100%{
    transform:scale(0);
    opacity:0;
  }
}

@keyframes moveGlow{
  from{
    transform:translate(0,0);
  }
  to{
    transform:translate(100px,80px);
  }
}

@keyframes moveGlow2{
  from{
    transform:translate(0,0);
  }
  to{
    transform:translate(-100px,-80px);
  }
}

/* MOBILE */
@media(max-width:768px){

  h1{
    font-size:65px;
  }

  .birthday-text{
    font-size:55px;
    padding:0 20px;
  }

  p,.wish{
    font-size:20px;
  }

  .btn{
    font-size:18px;
    padding:15px 40px;
  }

}

</style>
</head>

<body>

<div class="container" id="main">

  <h1>💖 Anjali 💖</h1>

  <p>Tap the magical surprise ✨</p>

  <button class="btn" onclick="showLove()">
    🎉 Open Surprise 🎉
  </button>

</div>

<script>

/* OPEN SURPRISE */
function showLove(){

  document.body.innerHTML=`

  <div class="birthday-page">

      <h1 class="birthday-text">
      🎂 Happy Birthday Anjali 💖
      </h1>

      <p class="wish">
     You are pure happiness ✨💖

      </p>

  </div>

  `;

  startEffects();
}

/* HEARTS */
function createHeart(){

  const heart=document.createElement("div");

  heart.classList.add("heart");

  const hearts=["💖","💕","💗","💘","💝"];

  heart.innerHTML=hearts[Math.floor(Math.random()*hearts.length)];

  heart.style.left=Math.random()*100+"vw";

  heart.style.fontSize=(20+Math.random()*50)+"px";

  heart.style.animationDuration=(4+Math.random()*4)+"s";

  document.body.appendChild(heart);

  setTimeout(()=>{
    heart.remove();
  },8000);
}

/* CONFETTI */
function createConfetti(){

  const conf=document.createElement("div");

  conf.classList.add("confetti");

  const colors=[
  "#ff006e",
  "#ff4da6",
  "#ffffff",
  "#ffd6e0",
  "#ff85b3",
  "#ffe5ec"
  ];

  conf.style.background=
  colors[Math.floor(Math.random()*colors.length)];

  conf.style.left=Math.random()*100+"vw";

  conf.style.animationDuration=
  (2+Math.random()*3)+"s";

  conf.style.width=
  (8+Math.random()*10)+"px";

  conf.style.height=
  conf.style.width;

  document.body.appendChild(conf);

  setTimeout(()=>{
    conf.remove();
  },5000);
}

/* SPARKLES */
function createSparkle(){

  const sparkle=document.createElement("div");

  sparkle.classList.add("sparkle");

  sparkle.style.left=Math.random()*100+"vw";

  sparkle.style.top=Math.random()*100+"vh";

  document.body.appendChild(sparkle);

  setTimeout(()=>{
    sparkle.remove();
  },2000);
}

/* START EFFECTS */
function startEffects(){

  setInterval(createHeart,180);

  setInterval(createConfetti,90);

  setInterval(createSparkle,250);
}

</script>

</body>
</html>
